---
import { getCollection } from "astro:content";

import Thread from "@components/Thread.astro";
import PostsLayout from "@layouts/PostsLayout.astro";

const posts = await getCollection("posts");

const newToOld = (a: Date, b: Date) => b.getTime() - a.getTime();
posts.sort((a, b) => newToOld(a.data.published, b.data.published));
---

<PostsLayout>
  {posts.map((post) => <Thread post={post} />)}
</PostsLayout>
